# ---------------------------------------------------------------------------
# SifaloPay Mini E-Commerce - Backend Environment Configuration
# Copy this file to ".env" and fill in the values.
# ---------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=4000

# Comma separated list of allowed frontend origins for CORS (production).
# In development any origin is accepted automatically.
CORS_ORIGIN=http://localhost:4000,http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Database (PostgreSQL + Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sifalopay_test?schema=public

# ---------------------------------------------------------------------------
# SifaloPay credentials (from https://pay.sifalo.com/business/merchant/api)
#
# API username — used for server-to-server Basic Auth (username:api_key).
# API key      — treat like a password; NEVER expose to the browser/frontend.
# ---------------------------------------------------------------------------
SIFALO_API_USERNAME=
SIFALO_API_KEY=

# SifaloPay gateway endpoints (defaults match the official WooCommerce plugin)
SIFALO_GATEWAY_URL=https://api.sifalopay.com/gateway/
SIFALO_VERIFY_URL=https://api.sifalopay.com/gateway/verify.php

# Your storefront URL (sent to SifaloPay as `url` on each charge)
SIFALO_STORE_URL=http://localhost:4000
SIFALO_CURRENCY=USD
SIFALO_CHANNEL=api

# Webhook signature secret (optional; for validating inbound callbacks)
SIFALO_WEBHOOK_SECRET=

# Public URLs used when creating a payment (callbacks + redirects)
SIFALO_CALLBACK_URL=http://localhost:4000/api/webhooks/sifalopay
SIFALO_RETURN_URL=http://localhost:4000/status

# ---------------------------------------------------------------------------
# Test mode
# When TEST_MODE=true the SifaloPay client is fully simulated (no real
# network calls). This lets you exercise the entire order/payment/webhook
# workflow with the $0.10 test amount before wiring real credentials.
# ---------------------------------------------------------------------------
TEST_MODE=true
TEST_AMOUNT=0.10

# Logging
LOG_LEVEL=info
