# ---------------------------------------------------------------------------
# SifaloPay Mini E-Commerce - Backend Environment Configuration
# Copy this file to ".env" and fill in the values.
# ---------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=4000

# Comma separated list of allowed frontend origins for CORS (production).
# In development any origin is accepted automatically.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Database (PostgreSQL + Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sifalopay_test?schema=public

# ---------------------------------------------------------------------------
# SifaloPay credentials
# Obtain from https://pay.sifalo.com/business/merchant/api
# The integration reads everything from here so keys can be rotated WITHOUT
# touching any source code.
# ---------------------------------------------------------------------------
SIFALO_API_KEY=
SIFALO_SECRET_KEY=
SIFALO_BASE_URL=https://api.sifalopay.com
SIFALO_MERCHANT_ID=

# Endpoint paths (relative to SIFALO_BASE_URL). Override if SifaloPay changes
# their routes - again, no code changes required.
SIFALO_CREATE_PATH=/v1/payments
SIFALO_VERIFY_PATH=/v1/payments

# Webhook signature secret used to validate incoming SifaloPay callbacks.
SIFALO_WEBHOOK_SECRET=

# Public URLs used when creating a payment (callbacks + redirects)
SIFALO_CALLBACK_URL=http://localhost:4000/api/webhooks/sifalopay
SIFALO_RETURN_URL=http://localhost:5173/status

# ---------------------------------------------------------------------------
# Test mode
# When TEST_MODE=true the SifaloPay client is fully simulated (no real
# network calls). This lets you exercise the entire order/payment/webhook
# workflow with the $0.10 test amount before wiring real credentials.
# ---------------------------------------------------------------------------
TEST_MODE=true
TEST_AMOUNT=0.10

# Logging
LOG_LEVEL=info
