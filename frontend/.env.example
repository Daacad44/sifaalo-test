# Base URL of the backend API. Only this PUBLIC value is exposed to the browser.
# SifaloPay secret keys NEVER live in the frontend.
#
# Use a relative "/api" in development so Vite proxies requests to the backend.
# This works for localhost, 127.0.0.1, and cloud preview URLs without extra
# port forwarding. Set an absolute URL only when the API is on a different host.
VITE_API_URL=/api
